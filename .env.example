# ALTCHA (https://altcha.org) — contact form anti-spam; generate with: openssl rand -hex 32
# Skipped automatically on localhost (contact + /ask). Set ALTCHA_ENFORCE_LOCALHOST=true to test locally.
ALTCHA_HMAC_SECRET=
# ALTCHA_ENFORCE_LOCALHOST=true

# Resend (https://resend.com) — contact form on /api/contact
RESEND_API_KEY=

# After chunhuduc.com is verified in Resend:
CONTACT_FROM_EMAIL=contact@chunhuduc.com
CONTACT_TO_EMAIL=contact@chunhuduc.com

# Optional display names (avoid noreply@ — use a replyable From address)
CONTACT_FROM_NAME=Chu Nhu Duc
CONTACT_SITE_NAME=chunhuduc.com

# Local dev before domain verify (Resend sandbox):
# CONTACT_FROM_EMAIL=onboarding@resend.dev
# CONTACT_TO_EMAIL=your-test@gmail.com

# Ask Đức AI (RAG) — Postgres + pgvector (Neon recommended; avoid Supabase free "project paused")
# Run supabase/migrations/001_rag.sql in your host SQL console, then paste pooler URL here.
DATABASE_URL=

# LLM: openai (default) or gemini — OpenAI requires migration 002 + re-ingest
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_EMBED_DIMENSIONS=1536

# GEMINI_API_KEY=
# GEMINI_CHAT_MODEL=gemini-2.5-flash
# GEMINI_EMBED_MODEL=gemini-embedding-001
# GEMINI_EMBED_DIMENSIONS=768

# RAG tuning
RAG_MIN_SIMILARITY=0.72
RAG_TOP_K=8

# Admin: /admin/knowledge (approve knowledge gaps)
ADMIN_SECRET=

# Local ingest from private SA workspace (optional)
# SA_KNOWLEDGE_ROOT=C:/BRAINSTORM/SA
